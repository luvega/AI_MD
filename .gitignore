# Obsidian volatile workspace state
.obsidian/workspace*.json
.obsidian/workspace
.obsidian/cache/
.obsidian/plugins/*/data.json

# OS and editor noise
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
~$*

# Runtime caches
__pycache__/
*.pyc
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
node_modules/
.venv/
venv/
book/site/
.tmp-qa/
.chrome-cdp.pid
.mkdocs-serve.pid

# Local-only raw learning materials. Keep the directory placeholder in Git, but
# never upload raw sources, extracted text, OCR output, torrents, or unpacked
# payloads.
06_原始学习素材/*
!06_原始学习素材/.gitkeep

# Generated or unpacked raw-source working trees. Existing tracked files remain
# tracked, but new OCR/extraction/unpacked payloads stay local by default.
06_原始学习素材/**/全文提取/
06_原始学习素材/**/解包/
06_原始学习素材/**/补充资料/
06_原始学习素材/**/安装包与视频/

# Large immutable raw sources stay on disk and are tracked by Markdown indexes,
# not by local Git by default.
*.pdf
*.rar
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.pptx
*.docx
*.xlsx
*.mp4
*.opju
*.opx

# Local transient exports
*.log
!log.md
